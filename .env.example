# ============================================================
# Restaurant Besteltool — omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# Voeg .env toe aan .gitignore — nooit committen!
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (transactionele e-mail) ────────────────────────────
# Aanmaken op: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry (error tracking) ───────────────────────────────────
# Aanmaken op: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Optioneel: omgeving-label zichtbaar in Sentry dashboard
ENVIRONMENT=production

# Optioneel: git SHA voor release-tracking in Sentry
# GIT_SHA=abc1234

# ── Backblaze B2 (dagelijkse backup) ─────────────────────────
# Aanmaken op: https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
B2_APPLICATION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
B2_BUCKET_NAME=besteltool-backups
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
