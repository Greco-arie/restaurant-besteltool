# ============================================================
# Restaurant Besteltool — omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# Voeg .env toe aan .gitignore — nooit committen!
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (transactionele e-mail) ────────────────────────────
# Aanmaken op: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Per-tenant verified domains (NIEUWE schakelaar). CSV, case-insensitive.
# Voor elk tenant-domein dat in Resend "Verified" is, voeg het FQDN toe.
# Voorbeeld: RESEND_VERIFIED_DOMAINS=family-maarssen.besteltool.nl,demo.besteltool.nl
# Tenants in deze lijst krijgen no-reply@<tenant>.besteltool.nl als afzender;
# alle andere vallen terug op de Resend-sandbox (onboarding@resend.dev).
# Zie docs/beta-demo/resend-setup.md voor DNS + verificatie-handleiding.
RESEND_VERIFIED_DOMAINS=

# LEGACY (deprecated) — blanket allow voor ALLE tenants. Laat op false staan
# zodra je bovenstaande lijst gebruikt. Blijft tijdelijk werken voor backwards-
# compat; logt een deprecation-warning bij gebruik.
RESEND_DOMEIN_GEVERIFIEERD=false

# ── Sentry (error tracking) ───────────────────────────────────
# Aanmaken op: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Optioneel: omgeving-label zichtbaar in Sentry dashboard
ENVIRONMENT=production

# Optioneel: git SHA voor release-tracking in Sentry
# GIT_SHA=abc1234

# ── Backblaze B2 (dagelijkse backup) ─────────────────────────
# Aanmaken op: https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
B2_APPLICATION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
B2_BUCKET_NAME=besteltool-backups
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
